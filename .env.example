# Server-side only — never exposed to the browser (recommended for production)
GEMINI_API_KEY=your_key_here

# Local dev fallback when GEMINI_API_KEY is unset (optional)
VITE_GEMINI_API_KEY=your_key_here

# Local: copy this file to .env
# Vercel: add GEMINI_API_KEY in Project Settings → Environment Variables
